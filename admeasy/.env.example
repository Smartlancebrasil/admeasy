NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_SUACHAVE

# URL pública do site em produção — usada em metadata (SEO), sitemap.xml,
# robots.txt e nos links enviados por e-mail (ex: checkout do Stripe).
NEXT_PUBLIC_SITE_URL=https://www.admeasy.com.br

# ID do container do Google Tag Manager (formato GTM-XXXXXXX). Opcional:
# se não for definido, nenhum script de rastreamento é carregado. Dentro do
# GTM é onde se configuram as tags de GA4, Meta Pixel e Google Ads.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
