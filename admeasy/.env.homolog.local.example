# Copie este arquivo para .env.homolog.local (nunca commitado — ver
# .gitignore) e preencha com os valores do projeto Supabase de
# homologação ("admeasy-homologacao"), nunca com os de produção.
#
# Uso local: renomeie/copie para .env.local só na hora de rodar contra
# homologação (nunca deixe os dois — produção e homologação — como
# .env.local ao mesmo tempo, pra não aplicar nada no projeto errado
# por engano). Ver docs/HOMOLOGATION_ENVIRONMENT_SETUP.md.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Usados só por scripts/seed-homologacao.mjs — nenhuma senha fica no
# código do script, todas vêm exclusivamente destas variáveis.
HOMOLOG_STAFF_PASSWORD=
HOMOLOG_LOCADOR_PASSWORD=
HOMOLOG_LOCATARIO_PASSWORD=

# Project ref esperado do projeto de homologação (ex.: "abcdefghijkl",
# a parte antes de ".supabase.co" na URL) — scripts/seed-homologacao.mjs
# aborta se NEXT_PUBLIC_SUPABASE_URL não bater exatamente com este valor.
EXPECTED_HOMOLOG_PROJECT_REF=
